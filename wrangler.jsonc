{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "domkirby-com",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "vars": {
    "PUBLIC_USE_CF_IMAGES": true,
  },
  "observability": {
    "enabled": true
  },
  "$schema": "node_modules/wrangler/config-schema.json"
}
