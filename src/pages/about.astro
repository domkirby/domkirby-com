---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Me" description="About Dom Kirby — cybersecurity professional, content creator, and technology enthusiast.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold text-white mb-8">About Me</h1>

    <div class="prose prose-invert prose-lg max-w-none
      prose-headings:text-white
      prose-a:text-green
      prose-strong:text-white
    ">
      <p>
        Hi, I'm Dom Kirby — a cybersecurity professional, content creator, and technology enthusiast
        based in the United States. I've spent over a decade working in IT and information security,
        helping organizations understand and manage risk.
      </p>

      <p>
        On this site I write about cybersecurity trends, technology tools, and the intersection of
        security with everyday business operations. My goal is to make complex topics accessible
        without dumbing them down.
      </p>

      <h2>What I Do</h2>
      <ul>
        <li>Cybersecurity consulting and advisory</li>
        <li>Content creation — articles, video, and podcasts</li>
        <li>Speaking and training</li>
      </ul>

      <h2>Get in Touch</h2>
      <p>
        Feel free to reach out via the <a href="/contact">contact page</a>, or connect with me
        on social media.
      </p>
    </div>
  </section>
</BaseLayout>
