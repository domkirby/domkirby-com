---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    category: 'Security',
    items: [
      { name: '1Password', description: 'Password manager', url: 'https://1password.com' },
      { name: 'SecretShare', description: 'Ephemeral secret sharing tool', url: 'https://github.com/domkirby/SecretShare' },
    ],
  },
  {
    category: 'Microsoft Tools',
    items: [
      { name: 'Maester', description: 'A project by Merill Fernando that enabled automated testing of Microsoft security posture, particularly useful for Entra ID. It’s also a framework that can be used to write any number of automated tests. This enables regression testing of your security posture.', url: 'https://maester.dev/?utm_source=domkirby.com' },
      { name: 'cmd.ms', description: 'cmd.ms is a useful set of shortcuts but, more importantly offers browser extensions for Edge and Chrome that make accessing the various Microsoft admin portals easy!', url: 'https://cmd.ms/' },
      { name: 'Graph X-Ray', description: 'A super nifty browser addon that will convert your navigation in admin centers to Graph PowerShell commands!', url: 'https://graphxray.merill.net/' },
      { name: 'Refined Microsoft Learn', description: 'A helpful browser extension that makes browsing MS Learn a little more streamlined.', url: 'https://github.com/merill/refined-microsoft-learn?tab=readme-ov-file' },
    ],
  },
];
---

<BaseLayout title="Tools and Stuff" description="Tools and software Dom Kirby uses and recommends.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold text-white mb-4">Tools and Stuff</h1>
    <p class="text-white/70 mb-12">
      A curated list of tools, software, and resources I use and recommend. This page is updated
      as my toolkit evolves.
    </p>

    {tools.map(section => (
      <div class="mb-12">
        <h2 class="text-xl font-bold text-green uppercase tracking-widest mb-6">{section.category}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {section.items.map(tool => (
            <a
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-white/5 border border-white/10 rounded-xl p-5 hover:border-green/40 transition-colors group"
            >
              <h3 class="font-bold text-white group-hover:text-green transition-colors mb-1">{tool.name}</h3>
              <p class="text-white/60 text-sm">{tool.description}</p>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
