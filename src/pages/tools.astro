---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    category: 'Security',
    items: [
      { name: 'Bitwarden', description: 'Open-source password manager', url: 'https://bitwarden.com' },
      { name: 'KeePassXC', description: 'Local password manager for offline use', url: 'https://keepassxc.org' },
      { name: 'Authy', description: 'Multi-device TOTP authenticator', url: 'https://authy.com' },
    ],
  },
  {
    category: 'Productivity',
    items: [
      { name: 'Notion', description: 'Notes, docs, and project management', url: 'https://notion.so' },
      { name: 'VS Code', description: 'Code editor of choice', url: 'https://code.visualstudio.com' },
    ],
  },
  {
    category: 'Content Creation',
    items: [
      { name: 'OBS Studio', description: 'Open source video recording and streaming', url: 'https://obsproject.com' },
      { name: 'DaVinci Resolve', description: 'Professional video editing', url: 'https://www.blackmagicdesign.com/products/davinciresolve' },
    ],
  },
];
---

<BaseLayout title="Tools and Stuff" description="Tools and software Dom Kirby uses and recommends.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold text-white mb-4">Tools and Stuff</h1>
    <p class="text-white/70 mb-12">
      A curated list of tools, software, and resources I use and recommend. This page is updated
      as my toolkit evolves.
    </p>

    {tools.map(section => (
      <div class="mb-12">
        <h2 class="text-xl font-bold text-green uppercase tracking-widest mb-6">{section.category}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {section.items.map(tool => (
            <a
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-white/5 border border-white/10 rounded-xl p-5 hover:border-green/40 transition-colors group"
            >
              <h3 class="font-bold text-white group-hover:text-green transition-colors mb-1">{tool.name}</h3>
              <p class="text-white/60 text-sm">{tool.description}</p>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
