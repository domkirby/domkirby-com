---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Dom Kirby.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold text-white mb-4">Contact</h1>
    <p class="text-white/70 mb-10">
      Have a question, a speaking opportunity, or just want to say hello? Reach out using
      any of the options below.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">

      <a
        href="https://linkedin.com/in/dominickirby"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-green/40 transition-colors group"
      >
        <h2 class="text-lg font-bold text-white group-hover:text-green transition-colors mb-1">LinkedIn (Preferred)</h2>
        <p class="text-white/60 text-sm">linkedin.com/in/dominickirby</p>
      </a>

      <a
        href="https://twitter.com/dom_kirby"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-green/40 transition-colors group"
      >
        <h2 class="text-lg font-bold text-white group-hover:text-green transition-colors mb-1">Twitter / X</h2>
        <p class="text-white/60 text-sm">@dom_kirby</p>
      </a>

      <a
        href="#"
        class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-green/40 transition-colors group"
        data-signal-username="domkirby.26"
        id="signalLink"
      >
        <h2 class="text-lg font-bold text-white mb-1">Signal</h2>
        <p class="text-white/60 text-sm">@domkirby.26</p>
      </a>

      <a
        href="https://bsky.app/profile/domkirby.com"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-green/40 transition-colors group"
      >
        <h2 class="text-lg font-bold text-white group-hover:text-green transition-colors mb-1">Bluesky</h2>
        <p class="text-white/60 text-sm">@domkirby.com</p>
      </a>

      

      <a
        href="https://youtube.com/@domkirby"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-green/40 transition-colors group"
      >
        <h2 class="text-lg font-bold text-white group-hover:text-green transition-colors mb-1">YouTube</h2>
        <p class="text-white/60 text-sm">@domkirby</p>
      </a>
    </div>
  </section>
  <script>
    //copy to clipboard for signal username
    document.getElementById('signalLink').addEventListener('click', function(e) {
      e.preventDefault();
      const username = this.getAttribute('data-signal-username');
      navigator.clipboard.writeText(username).then(() => {
        alert('Signal username copied to clipboard: ' + username);
      }).catch(err => {
        alert('Failed to copy: ' + err);
      });
    });
  </script>
</BaseLayout>
