---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );
  return paginate(sortedPosts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout title="Blog" description="All posts from Dom Kirby — security, technology, and insights.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-white mb-2">Blog</h1>
    <p class="text-white/60 mb-10">{page.total} posts</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {page.data.map(post => <PostCard post={post} />)}
    </div>

    {page.lastPage > 1 && (
      <nav class="flex items-center justify-center gap-6 mt-12" aria-label="Blog pagination">
        {page.url.prev ? (
          <a href={page.url.prev} class="text-sm font-medium text-green hover:underline">← Newer posts</a>
        ) : (
          <span class="text-sm font-medium text-white/30">← Newer posts</span>
        )}
        <span class="text-sm text-white/50">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next ? (
          <a href={page.url.next} class="text-sm font-medium text-green hover:underline">Older posts →</a>
        ) : (
          <span class="text-sm font-medium text-white/30">Older posts →</span>
        )}
      </nav>
    )}
  </section>
</BaseLayout>
