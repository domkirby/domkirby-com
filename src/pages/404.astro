---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="This page could not be found.">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-green font-mono text-6xl font-bold mb-4">404</p>
    <h1 class="text-3xl font-bold text-white mb-4">Page Not Found</h1>
    <p class="text-white/70 text-lg mb-4">
      I recently rebuilt this site from scratch, so some pages and links may have moved.
    </p>
    <p class="text-white/50 mb-10">
      Try the links below, or use your browser's back button to return to where you came from.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/" class="bg-green text-navy font-bold px-6 py-3 rounded-lg hover:bg-green/90 transition-colors">
        Home
      </a>
      <a href="/blog" class="border border-white/20 text-white font-medium px-6 py-3 rounded-lg hover:border-green/40 hover:text-green transition-colors">
        Blog Archive
      </a>
    </div>
  </section>
</BaseLayout>
