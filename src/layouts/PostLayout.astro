---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  categories?: string[];
  coverImage?: string;
  postSlug?: string;
  year?: string;
  description?: string;
}

const { title, date, categories = [], coverImage, postSlug, year, description } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const coverImageUrl = coverImage && postSlug && year
  ? `/posts/${year}/${postSlug}/images/${coverImage}`
  : null;
---

<BaseLayout title={title} description={description} ogImage={coverImageUrl ?? undefined}>
  <!-- Hero / cover image -->
  {coverImageUrl ? (
    <div class="w-full max-h-[480px] overflow-hidden">
      <img
        src={coverImageUrl}
        alt={title}
        class="w-full h-full object-cover"
      />
    </div>
  ) : (
    <div class="w-full h-32 bg-gradient-to-r from-navy via-linkblue to-navy border-b border-green/20" />
  )}

  <!-- Post header -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-4">
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {categories.map(cat => (
          <span class="text-xs font-semibold uppercase tracking-widest text-green">
            {cat}
          </span>
        ))}
      </div>
    )}
    <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-3">{title}</h1>
    <p class="text-white/50 text-sm">{formattedDate}</p>
  </div>

  <!-- Post content -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <article class="prose prose-invert prose-lg max-w-none
      prose-headings:text-white
      prose-a:text-green prose-a:no-underline hover:prose-a:underline
      prose-strong:text-white
      prose-code:text-green prose-code:bg-white/10 prose-code:px-1 prose-code:rounded
      prose-pre:bg-white/5 prose-pre:border prose-pre:border-white/10
      prose-blockquote:border-l-green prose-blockquote:text-white/70
      prose-img:rounded-lg prose-img:mx-auto
    ">
      <slot />
    </article>
  </div>
</BaseLayout>
