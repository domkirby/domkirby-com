    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/60 text-sm">
        &copy; {year} Dom Kirby. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="https://twitter.com/domkirby" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-green text-sm transition-colors">Twitter</a>
        <a href="https://linkedin.com/in/domkirby" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-green text-sm transition-colors">LinkedIn</a>
        <a href="https://youtube.com/@domkirby" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-green text-sm transition-colors">YouTube</a>
      </div>
    </div>
