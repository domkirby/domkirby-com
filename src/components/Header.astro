---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Store', href: 'https://store.domkirby.com', external: true },
  { label: 'About Me', href: '/about' },
  { label: 'Tools and Stuff', href: '/tools' },
  { label: 'Contact', href: '/contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="bg-navy border-b border-green/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img src="/dk-light.png" alt="Dom Kirby" class="h-10 w-auto" />
      </a>

      <!-- Nav links -->
      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'text-green'
                : 'text-white/80 hover:text-green',
            ]}
            {...link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
          >
            {link.label}
            {link.external && (
              <svg class="inline ml-1 w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            )}
          </a>
        ))}
      </nav>

      <!-- Mobile hamburger placeholder -->
      <button class="md:hidden text-white/80 hover:text-green" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
