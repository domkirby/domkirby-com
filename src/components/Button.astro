---
interface Props {
  link: string;
  newwindow?: boolean;
}

const { link, newwindow = false } = Astro.props;
---

<a
  href={link}
  style="display:inline-block; background:#7ed957; color:#0b1970; font-weight:700; padding:0.75rem 1.5rem; border-radius:0.5rem; text-decoration:none;"
  {...newwindow ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <slot />
</a>
