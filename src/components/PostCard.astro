---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, categories, coverImage } = post.data;

// Derive the post's year from the slug (e.g. "2024/cybersecurity-2025-predictions")
const slugParts = post.slug.split('/');
const year = slugParts[0];
const postSlug = slugParts.slice(1).join('/');

const postUrl = `/blog/${post.slug}`;

// Build the cover image URL from the public directory
// Images are served from /posts/{year}/{slug}/images/{filename}
const coverImageUrl = coverImage
  ? `/posts/${year}/${postSlug}/images/${coverImage}`
  : null;

// Format date
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Generate excerpt from body content
const bodyText = post.body
  .replace(/^---[\s\S]*?---/, '')        // strip frontmatter
  .replace(/#+\s+.*/g, '')              // strip headings
  .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // strip links
  .replace(/[*_`~]/g, '')              // strip markdown symbols
  .replace(/\n+/g, ' ')               // collapse newlines
  .trim();

const excerpt = bodyText.slice(0, 160) + (bodyText.length > 160 ? '...' : '');
---

<article class="bg-navy border border-white/10 rounded-xl overflow-hidden hover:border-green/40 transition-colors group">
  {coverImageUrl && (
    <a href={postUrl} class="block overflow-hidden aspect-video">
      <img
        src={coverImageUrl}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </a>
  )}
  {!coverImageUrl && (
    <a href={postUrl} class="block aspect-video bg-gradient-to-br from-navy to-linkblue flex items-center justify-center">
      <span class="text-green text-4xl font-bold opacity-20">DK</span>
    </a>
  )}

  <div class="p-5">
    <!-- Categories -->
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {categories.map(cat => (
          <span class="text-xs font-semibold uppercase tracking-wide text-green">
            {cat}
          </span>
        ))}
      </div>
    )}

    <!-- Title -->
    <h2 class="text-lg font-bold mb-2 leading-snug">
      <a href={postUrl} class="text-white hover:text-green transition-colors">
        {title}
      </a>
    </h2>

    <!-- Date -->
    <p class="text-white/50 text-xs mb-3">{formattedDate}</p>

    <!-- Excerpt -->
    <p class="text-white/70 text-sm leading-relaxed line-clamp-3">{excerpt}</p>

    <!-- Read more -->
    <a href={postUrl} class="inline-flex items-center gap-1 mt-4 text-sm text-green font-medium hover:underline">
      Read more
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
